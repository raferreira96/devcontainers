{
	"name": "Node.js",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "22-bookworm"
		}
	},
	// Usuário não-root já presente na imagem oficial do Node.
	"remoteUser": "node",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"username": "node"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			}
		}
	},
	// Confirma que os três gerenciadores de pacotes estão disponíveis.
	"postCreateCommand": "node -v && npm -v && yarn -v && pnpm -v"
}
